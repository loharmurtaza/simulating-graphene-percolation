# Project root directory
PROJECT_ROOT=./

# Data Directories
DATA_DIR=./data
RAW_DIR=./data/raw
EXPERIMENTAL_RAW_PATH=./data/raw/experimental_raw.csv
PROCESSED_DIR=./data/processed
OUTPUT_DIR=./data/output

# Grid Size (microns)
GRID_SIZE_MICRONS=100

# Number of Circles
NUM_CIRCLES=48
RADIUS_MICRONS=0.0914e-3
